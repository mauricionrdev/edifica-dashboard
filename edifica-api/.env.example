# ==============================================================
#  Edifica API - variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores.
# ==============================================================

# Porta HTTP
PORT=3001

# Origem do frontend (para CORS). Em dev: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# JWT - gere com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=trocar-em-producao-por-hex-de-64-bytes
JWT_EXPIRES_IN=12h

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edifica
DB_USER=edifica_user
DB_PASS=edifica_pass
DB_CONNECTION_LIMIT=10

# Seed do primeiro admin (usado por `npm run seed`)
SEED_ADMIN_NAME=Super Admin Edifica
SEED_ADMIN_EMAIL=superadmin@edifica.com.br
SEED_ADMIN_PASSWORD=Edifica@2026!
