{
  "name": "edifica-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit:css": "node scripts/audit-css.mjs",
    "audit:css:strict": "node scripts/audit-css.mjs --strict",
    "hooks:install": "git config core.hooksPath .githooks",
    "precommit:check": "npm run audit:css:strict && npm run build",
    "verify:prod": "node scripts/verify-production.mjs",
    "release:check": "npm run audit:css:strict && npm run verify:prod && npm run build",
    "verify:v2": "node scripts/verify-v2-promotion.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "vite": "^5.4.8"
  }
}
