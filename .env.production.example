# Frontend Vite - Hostinger
# Use a URL publica da API, sempre terminando em /api e sem barra final.
VITE_API_URL=https://api.seu-dominio.com/api

# Promoção controlada V2 — produção deve começar com tudo desligado.
# Ativar uma flag exige novo build do frontend e checklist de rollback.
VITE_PROMOTE_CLIENTES_V2=false
VITE_PROMOTE_GESTAO_TRAFEGO_V2=false
VITE_PROMOTE_MODELO_OFICIAL_V2=false
VITE_PROMOTE_PERFIL_V2=false
VITE_PROMOTE_EQUIPE_V2=false
VITE_PROMOTE_PROJETOS_V2=false
