# URL base da API Edifica (sem barra no final).
# Em desenvolvimento local, aponte para o backend edifica-api rodando.
VITE_API_URL=http://localhost:3001/api

# Promoção controlada V2 — padrão seguro: desligado.
# Só altere para true depois de validar a rota em /v2 e manter fallback em /legacy.
VITE_PROMOTE_CLIENTES_V2=false
VITE_PROMOTE_GESTAO_TRAFEGO_V2=false
VITE_PROMOTE_MODELO_OFICIAL_V2=false
VITE_PROMOTE_PERFIL_V2=false
VITE_PROMOTE_EQUIPE_V2=false
VITE_PROMOTE_PROJETOS_V2=false
